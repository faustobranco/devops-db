{
	"blocks": [
		{
			"type": "section",
			"accessory": {
				"type": "image",
				"image_url": "https://devops-db.com/wp-content/uploads/2026/03/error_17383012.png",
				"alt_text": "Error icon"
			},
			"text": {
				"type": "mrkdwn",
				"text": "*Deployment Failed*\nService: ${service}\nEnvironment: ${environment}"
			}
		},
		{
			"type": "section",
			"fields": [
				{
					"type": "mrkdwn",
					"text": "*Service:*\n${service}"
				},
				{
					"type": "mrkdwn",
					"text": "*Environment:*\n${environment}"
				},
				{
					"type": "mrkdwn",
					"text": "*Status:*\nFailed"
				},
				{
					"type": "mrkdwn",
					"text": "*Version:*\n${version}"
				}
			]
		},
		{
			"type": "section",
			"text": {
				"type": "mrkdwn",
				"text": "*Error:*\n${errorMessage}"
			}
		},
		{
			"type": "context",
			"elements": [
				{
					"type": "mrkdwn",
					"text": "🔗 <${urlPipeline}|View pipeline>"
				}
			]
		},
		{
			"type": "context",
			"elements": [
				{
					"type": "mrkdwn",
					"text": "🕒 ${eventDate}"
				}
			]
		}
	]
}