{
	"blocks": [
		{
			"type": "section",
			"accessory": {
				"type": "image",
				"image_url": "https://devops-db.com/wp-content/uploads/2026/03/three-quarter_17382650.png",
				"alt_text": "Approval pending"
			},
			"text": {
				"type": "mrkdwn",
				"text": "*Deployment pending approval.*\nService: ${service}\nEnvironment: ${environment}"
			}
		},
		{
			"type": "section",
			"fields": [
				{
					"type": "mrkdwn",
					"text": "*Service:*\n${service}"
				},
				{
					"type": "mrkdwn",
					"text": "*Environment:*\n${environment}"
				},
				{
					"type": "mrkdwn",
					"text": "*Status:*\nWaiting for Approval"
				},
				{
					"type": "mrkdwn",
					"text": "*Version:*\n${version}"
				}
			]
		},
		{
			"type": "actions",
			"elements": [
				{
					"type": "button",
					"text": {
						"type": "plain_text",
						"text": "Approve or Reject"
					},
					"style": "primary",
					"url": "${urlApproval}"
				}
			]
		}
	]
}